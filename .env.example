# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and service-role key (server-side only — bypasses RLS).
# Get from: https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Cloud ─────────────────────────────────────────────────────────────
# Used by ADK agents (debrief, coach) and Vertex AI / Gemini Live (Q&A judges).
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global

# Routes @iqai/adk to Vertex AI (GCP billing) instead of AI Studio.
# Requires Application Default Credentials locally:
#   gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=true

# AI Studio key — used ONLY for Q&A ephemeral token minting (Gemini Live).
# Not used by ADK agents.
GEMINI_API_KEY=

# Optional — kept for legacy direct Vertex calls.
GOOGLE_API_KEY=

# ── Storage ──────────────────────────────────────────────────────────────────
# Leave empty in local dev — upload routes fall back to mock signed URLs
# because user ADC cannot sign V4 URLs (only service accounts can).
GCS_BUCKET_NAME=

# ── Cloud Tasks ──────────────────────────────────────────────────────────────
# Two queues: brief extraction + transcription. Created by deploy automation.
CLOUD_TASKS_BRIEF_QUEUE=brief-extraction
CLOUD_TASKS_TRANSCRIBE_QUEUE=transcribe
CLOUD_TASKS_LOCATION=us-central1
# Service account that signs OIDC tokens on outbound task requests.
# Format: <name>@<project>.iam.gserviceaccount.com
CLOUD_TASKS_SERVICE_ACCOUNT=

# ── Production-only OIDC verification ────────────────────────────────────────
# Set in Cloud Run, not locally. Both must be set or all task deliveries 403.
# TASK_AUDIENCE — the deployed Cloud Run service URL (e.g. https://<svc>-<hash>-uc.a.run.app)
# TASK_ALLOWED_SERVICE_ACCOUNTS — comma-separated allowlist of caller SAs
TASK_AUDIENCE=
TASK_ALLOWED_SERVICE_ACCOUNTS=

# ── Dev mode ─────────────────────────────────────────────────────────────────
# When true, brief extraction runs inline (no Cloud Tasks / GCS needed).
# Set to false in production.
BRIEF_EXTRACTION_DEV_MODE=true
